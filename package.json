{
  "name": "tanktech-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "dev:public": "npm run dev:public -w apps/web",
    "expose": "npx localtunnel --port 3000",
    "bootstrap": "powershell -ExecutionPolicy Bypass -File scripts/bootstrap.ps1",
    "build": "npm run build -w apps/web",
    "lint": "npm run lint -w apps/web",
    "test": "npm run test -w apps/web",
    "typecheck": "npm run typecheck -w apps/web"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
